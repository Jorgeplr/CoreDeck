# ============================================================
# CoreDesk API — Production Environment
# Copia este archivo como .env y rellena los valores reales
# ============================================================

# Base de datos (el host "mysql" es el nombre del servicio en docker-compose.prod.yml)
DATABASE_URL="mysql://coredesk_user:MYSQL_PASSWORD@mysql:3306/coredesk"

# Contraseñas de MySQL (deben coincidir con las del compose)
MYSQL_ROOT_PASSWORD="cambia_esto_root"
MYSQL_PASSWORD="cambia_esto_user"

# JWT — genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="genera_64_chars_random"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_DAYS=7
COOKIE_SECRET="genera_otro_64_chars_random"

# Entorno
NODE_ENV="production"
API_PORT=3001

# CORS — URL pública del frontend
CORS_ORIGIN="https://app.tudominio.com"

# URL pública de la API (usada por el build de Vite para el frontend)
VITE_API_URL="https://api.tudominio.com/api"

# Email (Nodemailer — para recordatorios)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="tu@gmail.com"
SMTP_PASS="tu_app_password_de_gmail"
EMAIL_FROM="CoreDesk <noreply@tudominio.com>"

# Cron de recordatorios
REMINDER_CHECK_CRON="*/15 * * * *"
REMINDER_NOTIFY_HOURS_BEFORE=24
