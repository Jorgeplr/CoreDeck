# ============================================================
# CoreDesk — Production Environment (pegar en Dokploy → Environment)
# ============================================================
# La DATABASE_URL NO va aquí — el docker-compose.prod.yml la
# construye automáticamente usando MYSQL_PASSWORD.
# Solo necesitas las variables de abajo.
# ============================================================

# ── MySQL (el contenedor se crea dentro del mismo compose) ──
MYSQL_ROOT_PASSWORD="cambia_esto_root"
MYSQL_PASSWORD="cambia_esto_user"

# ── JWT — genera con: ──
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="genera_64_chars_random"
COOKIE_SECRET="genera_otro_64_chars_random"

# ── URLs públicas ──
# CORS_ORIGIN  → donde vive el frontend  (ej: https://app.tudominio.com)
# VITE_API_URL → donde vive la API       (ej: https://api.tudominio.com/api)
CORS_ORIGIN="https://app.tudominio.com"
VITE_API_URL="https://api.tudominio.com/api"

# ── Email (para notificaciones de recordatorios) ──
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="tu@gmail.com"
SMTP_PASS="tu_app_password_de_gmail"
EMAIL_FROM="CoreDesk <noreply@tudominio.com>"

