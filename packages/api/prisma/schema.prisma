generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// ─── AUTH & USERS ──────────────────────────────────────────────────────────────

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  username            String    @unique
  passwordHash        String
  displayName         String?
  avatarUrl           String?
  isActive            Boolean   @default(true)
  emailVerified       Boolean   @default(false)
  emailVerifyToken    String?   @unique @db.VarChar(200)
  emailVerifyExpires  DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  refreshTokens      RefreshToken[]
  groupMembers       GroupMember[]
  vaultEntries       VaultEntry[]
  assignedTickets    Ticket[]          @relation("AssignedTickets")
  createdTickets     Ticket[]          @relation("CreatedTickets")
  ticketHistory      TicketHistory[]
  ticketComments     TicketComment[]
  notes              Note[]
  reminders          Reminder[]
  attachments        Attachment[]
  ticketTemplates    TicketTemplate[]
  recurringTickets   RecurringTicket[] @relation("RecurringCreated")
  recurringAssigned  RecurringTicket[] @relation("RecurringAssigned")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique @db.VarChar(500)
  userId    String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── GROUPS ────────────────────────────────────────────────────────────────────

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  slug        String   @unique
  inviteCode  String   @unique @db.VarChar(10)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members          GroupMember[]
  vaultEntries     VaultEntry[]
  tickets          Ticket[]
  notes            Note[]
  ticketTemplates  TicketTemplate[]
  recurringTickets RecurringTicket[]

  @@map("groups")
}

model GroupMember {
  id       String          @id @default(cuid())
  userId   String
  groupId  String
  role     GroupMemberRole @default(MEMBER)
  joinedAt DateTime        @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
  @@map("group_members")
}

enum GroupMemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// ─── VAULT ─────────────────────────────────────────────────────────────────────

model VaultEntry {
  id                String          @id @default(cuid())
  title             String
  url               String?
  usernameEncrypted String?         @db.Text
  passwordEncrypted String          @db.Text
  notesEncrypted    String?         @db.Text
  iv                String
  scope             VaultEntryScope @default(PERSONAL)
  userId            String?
  groupId           String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user  User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([groupId])
  @@map("vault_entries")
}

enum VaultEntryScope {
  PERSONAL
  GROUP
}

// ─── FLOW ──────────────────────────────────────────────────────────────────────

model Ticket {
  id           String         @id @default(cuid())
  title        String
  description  String?        @db.Text
  status       TicketStatus   @default(OPEN)
  priority     TicketPriority @default(NORMAL)
  scope        TicketScope    @default(INDIVIDUAL)
  dueDate      DateTime?
  dueNotifiedAt DateTime?
  createdById  String
  assignedToId String?
  groupId      String?
  templateId   String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  createdBy  User            @relation("CreatedTickets", fields: [createdById], references: [id])
  assignedTo User?           @relation("AssignedTickets", fields: [assignedToId], references: [id])
  group      Group?          @relation(fields: [groupId], references: [id], onDelete: SetNull)

  history     TicketHistory[]
  labels      TicketLabel[]
  comments    TicketComment[]
  attachments Attachment[]

  @@index([createdById])
  @@index([assignedToId])
  @@index([groupId])
  @@index([status])
  @@map("tickets")
}

model TicketHistory {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String
  action    String
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([ticketId])
  @@map("ticket_history")
}

model Label {
  id    String @id @default(cuid())
  name  String @unique
  color String @default("#6b7280")

  tickets TicketLabel[]

  @@map("labels")
}

model TicketLabel {
  ticketId String
  labelId  String

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  label  Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([ticketId, labelId])
  @@map("ticket_labels")
}

model TicketComment {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([ticketId])
  @@map("ticket_comments")
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  IN_REVIEW
  RESOLVED
}

enum TicketPriority {
  CRITICAL
  URGENT
  NORMAL
  LOW
}

enum TicketScope {
  INDIVIDUAL
  GROUP
}

// ─── CONTEXT ───────────────────────────────────────────────────────────────────

model Note {
  id              String   @id @default(cuid())
  title           String
  content         String   @db.LongText
  isCollaborative Boolean  @default(false)
  userId          String?
  groupId         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user        User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  group       Group?       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  attachments Attachment[]

  @@index([userId])
  @@index([groupId])
  @@map("notes")
}

model Reminder {
  id          String         @id @default(cuid())
  title       String
  description String?
  dueAt       DateTime
  status      ReminderStatus @default(PENDING)
  notifiedAt  DateTime?
  userId      String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([dueAt])
  @@map("reminders")
}

enum ReminderStatus {
  PENDING
  NOTIFIED
  DISMISSED
  DONE
}

// ─── ATTACHMENTS ───────────────────────────────────────────────────────────────

model Attachment {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  ticketId     String?
  noteId       String?
  uploadedById String
  createdAt    DateTime @default(now())

  uploadedBy User    @relation(fields: [uploadedById], references: [id])
  ticket     Ticket? @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  note       Note?   @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([noteId])
  @@map("attachments")
}

// ─── TICKET TEMPLATES ──────────────────────────────────────────────────────────

model TicketTemplate {
  id          String         @id @default(cuid())
  name        String
  description String?
  title       String
  body        String?        @db.Text
  priority    TicketPriority @default(NORMAL)
  scope       TicketScope    @default(INDIVIDUAL)
  groupId     String?
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  createdBy User   @relation(fields: [createdById], references: [id])
  group     Group? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@index([groupId])
  @@map("ticket_templates")
}

// ─── RECURRING TICKETS ─────────────────────────────────────────────────────────

model RecurringTicket {
  id           String         @id @default(cuid())
  title        String
  description  String?        @db.Text
  priority     TicketPriority @default(NORMAL)
  scope        TicketScope    @default(INDIVIDUAL)
  groupId      String?
  assignedToId String?
  cronExpr     String
  createdById  String
  isActive     Boolean        @default(true)
  lastRun      DateTime?
  nextRunAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  createdBy  User   @relation("RecurringCreated", fields: [createdById], references: [id])
  group      Group? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  assignedTo User?  @relation("RecurringAssigned", fields: [assignedToId], references: [id])

  @@index([createdById])
  @@index([groupId])
  @@map("recurring_tickets")
}

// ─── CRON LOCKS ───────────────────────────────────────────────────────────────

model CronLock {
  name        String   @id
  lockedUntil DateTime?
  lockedBy    String?
  updatedAt   DateTime @updatedAt

  @@map("cron_locks")
}
